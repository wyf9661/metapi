# ─────────────────────────────────────────────────────────────
# Security (production)
# In production (NODE_ENV=production) the server REFUSES to start with
# default/insecure secrets. Generate strong unique values, e.g.:
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────

# Admin panel login token. Must be strong & unique in production (>=8 chars).
AUTH_TOKEN=change-me-admin-token

# Encryption key for stored upstream account credentials.
# MUST be a strong unique value AND different from AUTH_TOKEN in production.
ACCOUNT_CREDENTIAL_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Global proxy token for downstream clients.
# Recommended: leave global token DISABLED and generate per-project API keys
# in the UI (Downstream Keys). Default in production is DISABLED.
#   - dev/test: enabled by default (backward compatible)
#   - production: set ALLOW_GLOBAL_PROXY_TOKEN=true only if you really need it,
#     and then PROXY_TOKEN must be strong (>=8 chars).
# ALLOW_GLOBAL_PROXY_TOKEN=false
PROXY_TOKEN=change-me-proxy-sk-token

# Emergency escape hatch to bypass production security checks (NOT recommended).
# ALLOW_INSECURE_DEFAULTS=false

CHECKIN_CRON=0 8 * * *
BALANCE_REFRESH_CRON=0 * * * *
# Optional OAuth overrides. Fill the matching credentials when an override is enabled; Claude requires a client secret with no fallback.
CLAUDE_CLIENT_ID=
CLAUDE_CLIENT_SECRET=
# Codex OAuth override only needs CODEX_CLIENT_ID.
CODEX_CLIENT_ID=
# Gemini CLI override requires both GEMINI_CLI_CLIENT_ID and GEMINI_CLI_CLIENT_SECRET together.
GEMINI_CLI_CLIENT_ID=
GEMINI_CLI_CLIENT_SECRET=
SYSTEM_PROXY_URL=
WEBHOOK_URL=
BARK_URL=
SERVERCHAN_KEY=
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
MODEL_AVAILABILITY_PROBE_CONCURRENCY=1
MODEL_AVAILABILITY_PROBE_ENABLED=false
MODEL_AVAILABILITY_PROBE_INTERVAL_MS=1800000
MODEL_AVAILABILITY_PROBE_TIMEOUT_MS=15000
PORT=4000
DATA_DIR=./data
NOTIFY_COOLDOWN_SEC=300
ADMIN_IP_ALLOWLIST=

# ─────────────────────────────────────────────────────────────
# Reverse proxy / network
# ─────────────────────────────────────────────────────────────
# Trust X-Forwarded-For from a reverse proxy. Set false when the server is
# directly exposed to clients (prevents client IP spoofing / allowlist bypass).
# TRUST_PROXY=true
# Constrain trusted proxy hops (e.g. 1 when behind a single nginx/caddy).
# TRUST_PROXY_HOPS=1

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
# DB_TYPE=sqlite
# DB_URL=
# DB_SSL=false
# When DB_SSL=true, TLS certs are verified by default. Only for self-signed
# upstreams set this to false (NOT recommended in production).
# DB_SSL_REJECT_UNAUTHORIZED=true

TZ=Asia/Shanghai

# Static fallback max channel attempts when eligible-count lookup fails.
# PROXY_MAX_CHANNEL_ATTEMPTS=5
# Live multi-channel soft cap: min(eligiblePool, this). Default 8.
# PROXY_CHANNEL_FAILOVER_MAX_ATTEMPTS=8
# Explicit aggregate failover wall-clock budget in ms. 0 = soft default 45s
# for multi-channel pools (single-channel stays unlimited by this budget).
# Prefer PROXY_FIRST_BYTE_TIMEOUT_SEC for per-attempt slow cuts.
# PROXY_CHANNEL_FAILOVER_BUDGET_MS=0
